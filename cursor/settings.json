{
  "[gdscript]": {
    "editor.defaultFormatter": "DoHe.godot-format"
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "atlascode.bitbucket.enabled": false,
  "chat.editor.fontSize": 14,
  "cursor.chat.terminalShowHoverHint": false,
  "cursor.composer.backspaceRemoveContext": false,
  "cursor.composer.collapsePaneInputBoxPills": true,
  "cursor.composer.queueMessageDefaultBehavior": "stop-and-send",
  "cursor.composer.usageSummaryDisplay": "always",
  "debug.console.fontSize": 14,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.ignoreTrimWhitespace": true,
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.formatDocument": "always"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.foldingImportsByDefault": true,
  "editor.fontFamily": "'JetBrainsMono Nerd Font Mono', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "normal",
  "editor.formatOnSave": true,
  "editor.renderWhitespace": "none",
  "editor.showFoldingControls": "always",
  "explorer.confirmDragAndDrop": false,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "files.autoSave": "onFocusChange",
  "git-graph.repository.fetchAndPruneTags": true,
  "git.allowForcePush": true,
  "git.autofetch": true,
  "git.autoRepositoryDetection": true,
  "git.autoStash": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": false,
  "git.closeDiffOnOperation": true,
  "git.confirmSync": false,
  "git.defaultBranchName": "master",
  "git.detectSubmodules": true,
  "git.enableCommitSigning": true,
  "git.enableSmartCommit": true,
  "git.fetchOnPull": true,
  "git.followTagsWhenSync": true,
  "git.mergeEditor": true,
  "git.pruneOnFetch": true,
  "git.rebaseWhenSync": true,
  "git.replaceTagsWhenPull": true,
  "git.showCursorWorktrees": true,
  "git.terminalGitEditor": true,
  "gitlens.currentLine.enabled": false,
  "gitlens.graph.dimMergeCommits": true,
  "gitlens.graph.minimap.enabled": false,
  "gitlens.plusFeatures.enabled": false,
  "gitlens.rebaseEditor.ordering": "asc",
  "gitlens.remotes": [
    {
      "domain": "github.com",
      "type": "GitHub"
    },
    {
      "domain": "gitlab.com",
      "type": "GitLab"
    },
    {
      "domain": "git.efabrica.sk",
      "name": "eFabrica",
      "type": "GitLab"
    }
  ],
  "gitlens.showWhatsNewAfterUpgrades": false,
  "gitlens.views.commitDetails.files.layout": "list",
  "gitlens.views.commits.avatars": false,
  "gitlens.virtualRepositories.enabled": false,
  "godotFormatter.indentSize": 2,
  "godotFormatter.linterMaxLineLength": 120,
  "godotFormatter.useSpaces": true,
  "html.autoClosingTags": false,
  "javascript.autoClosingTags": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.enable": true,
  "notebook.showFoldingControls": "always",
  "redhat.telemetry.enabled": false,
  "scm.inputFontSize": 16,
  "search.exclude": {
    "**/.next": true,
    "**/.nuxt": true
  },
  "svelte.enable-ts-plugin": true,
  "terminal.integrated.defaultProfile.osx": "fish",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 14,
  "typescript.autoClosingTags": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vscode-neovim.neovimViewportHeightExtend": 1.5,
  "vscode-neovim.revealCursorScrollLine": true,
  "vue.autoInsert.dotValue": true,
  "window.autoDetectColorScheme": true,
  "workbench.activityBar.orientation": "vertical",
  "workbench.colorTheme": "Solarized Light",
  "workbench.editor.editorActionsLocation": "hidden",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromCodeNavigation": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.editor.limit.value": 1,
  "workbench.editor.showTabs": "none",
  "workbench.iconTheme": "eyecons",
  "workbench.layoutControl.enabled": false,
  "workbench.preferredDarkColorTheme": "Solarized Dark",
  "workbench.preferredLightColorTheme": "Solarized Light",
  "zenMode.fullScreen": false,
  "zenMode.hideActivityBar": false,
  "zenMode.showTabs": "none"
}
